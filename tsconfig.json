{
  "compilerOptions": {
    "target": "ES2022",

    "lib": ["DOM", "DOM.Iterable", "ES2023"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "noEmit": true,

    "verbatimModuleSyntax": true,

    "moduleDetection": "force",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"]
}
